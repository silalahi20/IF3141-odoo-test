<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_toko_produk_list" model="ir.ui.view">
        <field name="name">toko.produk.tree</field>
        <field name="model">toko.produk</field>
        <field name="arch" type="xml">
            <tree> 
                <field name="name"/>
                <field name="harga"/>
                <field name="stok"/>
            </tree>
        </field>
    </record>

    <record id="view_toko_produk_form" model="ir.ui.view">
        <field name="name">toko.produk.form</field>
        <field name="model">toko.produk</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="harga"/>
                        <field name="stok"/>
                        <field name="deskripsi"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_toko_produk" model="ir.actions.act_window">
        <field name="name">Produk</field>
        <field name="res_model">toko.produk</field>
        <field name="view_mode">tree,form</field> 
    </record>

    <menuitem id="menu_toko_root" name="Toko Sederhana" sequence="10"/>
    <menuitem id="menu_toko_produk" name="Produk" parent="menu_toko_root" action="action_toko_produk"/>
</odoo>