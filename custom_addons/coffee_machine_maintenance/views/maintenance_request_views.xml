<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================ MAINTENANCE REQUEST VIEWS ================ -->

    <!-- List View -->
    <record id="view_maintenance_request_list" model="ir.ui.view">
        <field name="name">coffee.maintenance.request.list</field>
        <field name="model">coffee.maintenance.request</field>
        <field name="arch" type="xml">
            <tree string="Maintenance Requests"
                  decoration-success="state == 'done'"
                  decoration-warning="state == 'in_progress'"
                  decoration-muted="state == 'cancelled'">
                <field name="name"/>
                <field name="machine_id"/>
                <field name="location"/>
                <field name="maintenance_type"/>
                <field name="request_date"/>
                <field name="technician_id"/>
                <field name="priority" widget="priority"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state == 'done'"
                       decoration-danger="state == 'cancelled'"/>
                <field name="cost" sum="Total Cost"/>
            </tree>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_maintenance_request_form" model="ir.ui.view">
        <field name="name">coffee.maintenance.request.form</field>
        <field name="model">coffee.maintenance.request</field>
        <field name="arch" type="xml">
            <form string="Maintenance Request">
                <header>
                    <button name="action_start" string="Start" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_done" string="Mark as Done" type="object"
                            class="btn-success" invisible="state != 'in_progress'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            class="btn-danger"
                            invisible="state in ['done', 'cancelled']"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                            invisible="state != 'cancelled'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Request Details">
                            <field name="machine_id"/>
                            <field name="machine_type" readonly="1"/>
                            <field name="location" readonly="1"/>
                            <field name="maintenance_type"/>
                            <field name="priority" widget="priority"/>
                        </group>
                        <group string="Assignment">
                            <field name="request_date"/>
                            <field name="date_completed" readonly="state != 'in_progress'"/>
                            <field name="technician_id"/>
                            <field name="cost"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Problem Description">
                            <field name="description"
                                   placeholder="Describe the issue or maintenance task..."
                                   readonly="state in ['done', 'cancelled']"/>
                        </page>
                        <page string="Resolution">
                            <field name="resolution_notes"
                                   placeholder="Describe the resolution, actions taken..."
                                   readonly="state in ['done', 'cancelled']"/>
                            <field name="parts_used"
                                   placeholder="List parts or materials used..."
                                   readonly="state in ['done', 'cancelled']"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Kanban View -->
    <record id="view_maintenance_request_kanban" model="ir.ui.view">
        <field name="name">coffee.maintenance.request.kanban</field>
        <field name="model">coffee.maintenance.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="name"/>
                <field name="machine_id"/>
                <field name="location"/>
                <field name="maintenance_type"/>
                <field name="technician_id"/>
                <field name="priority"/>
                <field name="state"/>
                <field name="request_date"/>
                <field name="cost"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_global_click">
                            <div class="o_kanban_card_header">
                                <div class="o_kanban_card_header_title">
                                    <div class="o_primary">
                                        <strong><field name="name"/></strong>
                                    </div>
                                    <div class="o_secondary">
                                        <field name="machine_id"/>
                                    </div>
                                </div>
                                <div class="o_kanban_manage_button_section">
                                    <field name="priority" widget="priority"/>
                                </div>
                            </div>
                            <div class="o_kanban_card_content">
                                <ul>
                                    <li>📍 <field name="location"/></li>
                                    <li>🔧 <field name="maintenance_type"/></li>
                                    <li>👤 <field name="technician_id"/></li>
                                    <li>📅 <field name="request_date"/></li>
                                    <li t-if="record.cost.value">
                                        💰 <field name="cost"/>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_maintenance_request_search" model="ir.ui.view">
        <field name="name">coffee.maintenance.request.search</field>
        <field name="model">coffee.maintenance.request</field>
        <field name="arch" type="xml">
            <search string="Search Maintenance Requests">
                <field name="name"/>
                <field name="machine_id"/>
                <field name="technician_id"/>
                <field name="location"/>
                <separator/>
                <filter string="New" name="draft" domain="[('state','=','draft')]"/>
                <filter string="In Progress" name="in_progress"
                        domain="[('state','=','in_progress')]"/>
                <filter string="Done" name="done" domain="[('state','=','done')]"/>
                <filter string="Cancelled" name="cancelled"
                        domain="[('state','=','cancelled')]"/>
                <separator/>
                <filter string="Preventive" name="preventive"
                        domain="[('maintenance_type','=','preventive')]"/>
                <filter string="Corrective" name="corrective"
                        domain="[('maintenance_type','=','corrective')]"/>
                <separator/>
                <filter string="Urgent / Critical" name="urgent"
                        domain="[('priority','in',['1','2'])]"/>
                <group expand="0" string="Group By">
                    <filter string="Machine" name="group_machine"
                            context="{'group_by': 'machine_id'}"/>
                    <filter string="Location" name="group_location"
                            context="{'group_by': 'location'}"/>
                    <filter string="Technician" name="group_technician"
                            context="{'group_by': 'technician_id'}"/>
                    <filter string="Type" name="group_type"
                            context="{'group_by': 'maintenance_type'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Sequence -->
    <record id="seq_maintenance_request" model="ir.sequence">
        <field name="name">Coffee Maintenance Request</field>
        <field name="code">coffee.maintenance.request</field>
        <field name="prefix">MNT/%(year)s/</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False"/>
    </record>

    <!-- Action -->
    <record id="action_maintenance_request" model="ir.actions.act_window">
        <field name="name">Maintenance Requests</field>
        <field name="res_model">coffee.maintenance.request</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="search_view_id" ref="view_maintenance_request_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No maintenance requests yet!
            </p>
            <p>Create a maintenance request to start tracking machine repairs and servicing.</p>
        </field>
    </record>

    <!-- Dashboard action (all open requests) -->
    <record id="action_maintenance_request_open" model="ir.actions.act_window">
        <field name="name">Open Requests</field>
        <field name="res_model">coffee.maintenance.request</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('state', 'in', ['draft', 'in_progress'])]</field>
        <field name="context">{'search_default_in_progress': 1}</field>
    </record>

</odoo>
